# ─── AI / API ────────────────────────────────────────────────────────────────
# Qwen 3.5 等 OpenAI互換APIのエンドポイント
OPENAI_API_BASE=https://api.openai.com/v1
# APIキー
OPENAI_API_KEY=your-api-key-here
# 使用するモデル名 (例: qwen3.5, gpt-4o)
OPENAI_MODEL=qwen3.5

# ─── GitHub ───────────────────────────────────────────────────────────────────
# PR作成に必要な Personal Access Token (repo スコープが必要)
GITHUB_TOKEN=your-github-token-here

# ─── 診断対象サービス ────────────────────────────────────────────────────────
# ヘッドレスブラウザ検証の対象URL
TARGET_BASE_URL=https://example.com
# 検証用ログインID
TARGET_USERNAME=test-user
# 検証用パスワード
TARGET_PASSWORD=test-password

# ─── ダッシュボード ────────────────────────────────────────────────────────
# Flaskセッション署名キー (本番環境では必ず変更してください)
FLASK_SECRET_KEY=change-me-in-production
# 管理者初期パスワード (初回起動時に使用)
ADMIN_PASSWORD=change-me
# デバッグモード (本番環境では 0 にしてください)
FLASK_DEBUG=0

# ─── データベース ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-db-password-here

# ─── スキャン実行時に設定 (docker compose run scanner 等で使用) ──────────
# SCAN_ID=20240101120000-1
# REPO_URL=https://github.com/owner/repo
